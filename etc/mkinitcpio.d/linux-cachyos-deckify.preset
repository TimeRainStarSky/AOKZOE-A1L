# mkinitcpio preset file for the 'linux-cachyos-deckify' package

#ALL_config="/etc/mkinitcpio.conf"
ALL_kver="/boot/vmlinuz-linux-cachyos-deckify"

PRESETS=('default' 'fallback')

#default_config="/etc/mkinitcpio.conf"
default_image="/boot/initramfs-linux-cachyos-deckify.img"
#default_uki="/efi/EFI/Linux/arch-linux-cachyos-deckify.efi"
#default_options="--splash /usr/share/systemd/bootctl/splash-arch.bmp"

fallback_config="/etc/mkinitcpio-fallback.conf"
fallback_image="/boot/initramfs-linux-cachyos-deckify-fallback.img"
#fallback_uki="/efi/EFI/Linux/arch-linux-cachyos-deckify-fallback.efi"
#fallback_options="-S autodetect"
